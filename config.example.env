# agent-pages config + state
#
# setup.sh writes the live copy to the plugin's persistent data dir
# (${CLAUDE_PLUGIN_DATA}/config.env, i.e. ~/.claude/plugins/data/<plugin-id>/config.env),
# which survives plugin updates. This file just documents the fields; edit the
# live copy to change values.
#
# Your "site" is a separate git repo you own (AGENT_PAGES_PATH), scaffolded from
# the plugin's templates/ on first setup and deployed to GitHub Pages (or any
# static host). Pages are organized by category: <category>/<yyyyMMdd>-<slug>.html.

# Absolute path to your site repo (where pages are written and pushed from).
AGENT_PAGES_PATH="$HOME/agent-pages"

# Git remote of your site repo (origin). Empty until you create it.
AGENT_PAGES_REPO=""

# Branch to publish from.
AGENT_PAGES_BRANCH="main"

# Public site base URL (optional). When set, publish.sh prints the live URL
# after pushing. Leave empty until you have a domain / Pages URL.
AGENT_PAGES_SITE_BASE_URL=""

# Site title shown on index.html. A trailing token wrapped like "<Pages/>"
# is rendered in a code/monospace style.
AGENT_PAGES_NAME="Agent <Pages/>"

# state (written by setup.sh; informational)
# AGENT_PAGES_SETUP_AT="2026-06-20T00:00:00Z"
