# agent-pages configuration
# Copy this file to ~/.claude/agent-pages/config.env (install.sh does it for you),
# then edit the values to match your setup.
#
# Your "gallery" is your own fork/clone of this repository. Generated pages are
# written into it and pushed to GitHub Pages (or any static host). Because the
# gallery IS this repo, scripts/ live right beside your pages.

# Absolute path to your gallery working copy (the fork clone).
AGENT_PAGES_GALLERY_PATH="$HOME/dev/agent-pages"

# Git remote of your gallery fork (used for first-time clone hints only).
AGENT_PAGES_REMOTE="git@github.com:wanggang316/agent-pages.git"

# Branch to publish from.
AGENT_PAGES_BRANCH="main"

# Public site base URL (optional). When set, publish.sh prints the live URL
# after pushing. Leave empty until you have a domain / Pages URL.
AGENT_PAGES_SITE_BASE_URL=""

# Gallery title shown on index.html. The trailing code-style token is styled
# like the upstream "<HTML />" mark.
AGENT_PAGES_GALLERY_NAME="Agent <Pages/>"

# Default top-level project folder. Empty = use the basename of the directory
# where /agent-pages is invoked (the current Claude Code working directory).
AGENT_PAGES_DEFAULT_PROJECT=""
